 def run_simulation():
     # Initialize systems
     llm_client = LLMClient(mock_mode=True)
     semantic_mem = SemanticMemory()
     episodic_mem = EpisodicMemory()
     procedural_mem = ProceduralMemory()

     # Load seed data
     seed_memory(semantic_mem, episodic_mem, procedural_mem)

     # Initialize agents
     master_planner = MasterPlanner(llm_client, {
         'semantic': semantic_mem,
         'episodic': episodic_mem,
         'procedural': procedural_mem
     })

     data_planner = DataStrategyPlanner(llm_client, ...)
     product_planner = ProductStrategyPlanner(llm_client, ...)
     outreach_planner = OutreachStrategyPlanner(llm_client, ...)

     master_planner.add_planners([data_planner, product_planner, outreach_planner])

     # Initialize actor agents
     scraper = ScraperActor(llm_client, ...)
     tool_builder = ToolBuilderActor(llm_client, ...)
     content_gen = ContentGeneratorActor(llm_client, ...)

     data_planner.add_actors([scraper])
     product_planner.add_actors([tool_builder])
     outreach_planner.add_actors([content_gen])

     # Load simulated external actors
     startups = [SimulatedStartup(s) for s in load_json('data/seed/startups.json')]
     vcs = [SimulatedVC(v) for v in load_json('data/seed/vcs.json')]

     # Run Build-Measure-Learn cycle
     for iteration in range(3):  # 3 iterations for demo
         print(f"\n=== ITERATION {iteration + 1} ===\n")

         # BUILD: Master planner coordinates building
         master_planner.run_build_phase()

         # MEASURE: Simulate user interactions
         metrics = simulate_interactions(startups, vcs, outreach_planner)

         # LEARN: Update memories based on outcomes
         master_planner.run_learn_phase(metrics)

         # Display results
         display_iteration_results(iteration, metrics)

 def simulate_interactions(startups, vcs, outreach_planner):
     """
     Simulate outreach campaign results
     """
     # Get generated outreach from content generator
     outreach_messages = outreach_planner.get_generated_outreach()

     # Simulate sending to startups
     responses = []
     for msg in outreach_messages:
         startup = random.choice(startups)
         response = startup.receive_outreach(msg)
         responses.append(response)

     # Calculate metrics
     response_rate = sum(1 for r in responses if r['response'] == 'interested') / len(responses)

     return {
         'response_rate': response_rate,
         'total_sent': len(outreach_messages),
         'interested': sum(1 for r in responses if r['response'] == 'interested')
     }

 if __name__ == "__main__":
     run_simulation()

