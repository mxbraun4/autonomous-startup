 2. VC Agent:
 # src/simulation/vc_agent.py
 class SimulatedVC(BaseAgent):
     def __init__(self, vc_profile):
         super().__init__(f"vc_{vc_profile['id']}", None, None)
         self.profile = vc_profile

     def evaluate_startup(self, startup_profile):
         """
         Simulate VC's evaluation of a startup
         """
         # Check alignment: sector, stage, geography
         alignment_score = self._calculate_alignment(startup_profile)

         if alignment_score > 0.7:
             return {'decision': 'meeting_request', 'score': alignment_score}
         elif alignment_score > 0.4:
             return {'decision': 'interested', 'score': alignment_score}
         else:
             return {'decision': 'pass', 'score': alignment_score}

     def _calculate_alignment(self, startup):
         # Simple scoring based on overlap
         sector_match = 1.0 if startup['sector'] in self.profile['sectors'] else 0.0
         stage_match = 1.0 if startup['stage'] == self.profile['stage_focus'] else 0.5
         return (sector_match + stage_match) / 2

