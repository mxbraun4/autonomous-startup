# LLM API Keys
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# Mock Mode (set to true for simulation without API calls)
MOCK_MODE=true

# Customer simulation seed data
CUSTOMER_SEED_PATH=data/seed/customers.json

# Logging
LOG_LEVEL=INFO

# Memory System Configuration
# Set to true to use legacy memory adapters instead of new backends
MEMORY_USE_LEGACY=false
# Root directory for memory persistence (ChromaDB, SQLite, checkpoints)
MEMORY_DATA_DIR=data/memory
# Embedding model: "default" (ONNX, no torch) or "sentence-transformers"
MEMORY_EMBEDDING_MODEL=default
# Working memory time-decay rate (0-1, lower = faster decay)
MEMORY_WM_DECAY_RATE=0.95
# Default token budget for working memory prompt packing
MEMORY_WM_DEFAULT_MAX_TOKENS=4000
