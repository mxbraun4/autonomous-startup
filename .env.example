# LLM API Keys
# Preferred hosted path: OpenRouter (supports per-role model routing)
OPENROUTER_API_KEY=your_openrouter_key_here

# OpenRouter / LiteLLM model routing (used when MOCK_MODE=false and OPENROUTER_API_KEY is set)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
COORDINATOR_MODEL=openrouter/moonshotai/kimi-k2.5
PRODUCT_MODEL=openrouter/deepseek/deepseek-v3.2
DEVELOPER_MODEL=openrouter/qwen/qwen3-coder-next
REVIEWER_MODEL=openrouter/qwen/qwen3-coder-next

# Optional legacy fallback providers (used only if OpenRouter is not configured)
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_MODEL=anthropic/claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4o-mini

# Serper.dev API key for real web search (optional; tools degrade gracefully without it)
SERPER_API_KEY=your_serper_api_key_here

# Mock Mode (set to true for simulation without API calls)
MOCK_MODE=true

# CrewAI runtime storage (workspace-local, writable in constrained environments)
CREWAI_LOCAL_APPDATA_DIR=data/crewai_local
CREWAI_DB_STORAGE_DIR=data/crewai_storage
CREWAI_STORAGE_NAMESPACE=autonomous-startup

# Optional telemetry overrides (mock-mode defaults disable telemetry)
# CREWAI_DISABLE_TELEMETRY=true
# CREWAI_DISABLE_TRACKING=true
# OTEL_SDK_DISABLED=true
# ANONYMIZED_TELEMETRY=false
# Customer simulation seed data
CUSTOMER_SEED_PATH=data/seed/customers.json
CUSTOMER_HYPOTHESES_PATH=data/seed/customer_hypotheses.json

# Logging
LOG_LEVEL=INFO

# Memory System Configuration
# Root directory for memory persistence (ChromaDB, SQLite, checkpoints)
MEMORY_DATA_DIR=data/memory

# Dynamic tool artifact persistence
GENERATED_TOOLS_DIR=data/generated_tools
GENERATED_TOOLS_RETENTION_DAYS=30
