{
  "readme_quick_start_heading": {
    "description": "Bounded README quick-start heading edit",
    "path": "README.md",
    "search": "# Unified runner (default mode: crewai)",
    "replace": "# Unified runner (default mode: crewai)",
    "max_replacements": 1,
    "allowed_edit_path_patterns": [
      "README.md"
    ],
    "allowed_edit_search_patterns": [
      "^\\#\\ Unified\\ runner\\ \\(default\\ mode:\\ crewai\\)$"
    ]
  },
  "quickstart_primary_command": {
    "description": "Bounded QUICKSTART command edit",
    "path": "QUICKSTART.md",
    "search": "python scripts/run.py",
    "replace": "python scripts/run.py",
    "max_replacements": 1,
    "allowed_edit_path_patterns": [
      "QUICKSTART.md"
    ],
    "allowed_edit_search_patterns": [
      "^python\\ scripts/run\\.py$"
    ]
  }
}
